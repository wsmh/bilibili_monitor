# ============================================
# B站评论监控器 - 环境变量配置模板
# 复制此文件为 .env 并填入你的实际配置
# ============================================

# B站UP主UID（要监控的UP主）
# 例如：1671203508（洪洪火火复盘）
UP_UID=1671203508

# 飞书机器人Webhook地址
# 从飞书群机器人设置中获取
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# ============================================
# B站登录态配置（重要！用于获取动态/充电专属内容评论）
# ============================================

# 方式1：直接填写完整的 Cookie 字符串（推荐）
# 从浏览器开发者工具 -> Application -> Cookies -> https://www.bilibili.com 复制
# 格式：key1=value1; key2=value2; ...
BILI_COOKIE=

# 方式2：或者单独填写以下字段（如果方式1不可用）
# 从浏览器的 Cookie 中提取对应的值
BILI_SESSDATA=
BILI_BILI_JCT=
BILI_BUVID3=
BILI_BUVID4=
BILI_DEDEUSERID=

# ============================================
# 高级配置（可选，保持默认即可）
# ============================================

# 抓取模式：browser（推荐）| api | auto
BILI_FETCH_MODE=browser

# Chrome/Chromium 浏览器路径（留空时自动探测；Windows 可填 C:\Program Files\Google\Chrome\Application\chrome.exe）
BILI_BROWSER_EXECUTABLE=

# 是否无头模式（true=不显示浏览器窗口，false=显示窗口用于调试）
BILI_BROWSER_HEADLESS=true

# 浏览器超时时间（毫秒）
BILI_BROWSER_TIMEOUT_MS=30000

# 检查间隔（秒）
CHECK_INTERVAL=10

# 触发风控后的冷却时间（秒）
SECURITY_COOLDOWN_SECONDS=120

# 高峰时段开始时间（HH:MM）
PEAK_START=09:20

# 高峰时段结束时间（HH:MM）
PEAK_END=09:40

# 高峰时段检查间隔（秒）
PEAK_INTERVAL_SECONDS=30

# 上午常规时段开始时间（HH:MM）
MORNING_START=09:40

# 上午常规时段结束时间（HH:MM）
MORNING_END=11:30

# 上午常规时段检查间隔（秒）
MORNING_INTERVAL_SECONDS=180

# 下午常规时段开始时间（HH:MM）
AFTERNOON_START=13:00

# 下午常规时段结束时间（HH:MM）
AFTERNOON_END=15:00

# 下午常规时段检查间隔（秒）
AFTERNOON_INTERVAL_SECONDS=180

# 其他时间检查间隔（秒）
DEFAULT_INTERVAL_SECONDS=1800

# 登录状态下最多获取评论页数
COMMENT_MAX_PAGES_AUTH=2

# 未登录状态下最多获取评论页数
COMMENT_MAX_PAGES_GUEST=1

# 数据文件路径
DATA_FILE=notified_comments.json
